generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  isVerified    Boolean   @default(false) @map("is_verified")
  isBanned      Boolean   @default(false) @map("is_banned")
  role          Role      @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  profile       Profile?
  posts         Post[]
  postLikes     PostLike[]
  comments      Comment[]
  followsFollowing Follows[] @relation("Following")
  followsFollower  Follows[] @relation("Follower")
  passesSent    Pass[]    @relation("PassSent")
  passesReceived Pass[]   @relation("PassReceived")
  matchesOne    Match[]   @relation("MatchOne")
  matchesTwo    Match[]   @relation("MatchTwo")
  conversationsOne Conversation[] @relation("ConversationOne")
  conversationsTwo Conversation[] @relation("ConversationTwo")
  messages      Message[]
  notifications Notification[]
  mbtiResults   MbtiTestResult[]
  auditLogs     AuditLog[]
  gameScores    GameScore[]

  @@map("users")
}

model Profile {
  userId        String    @id @map("user_id")
  username      String    @unique
  nickname      String?
  avatarUrl     String?   @map("avatar_url")
  mbtiType      String?   @map("mbti_type")
  mbtiCertLevel CertLevel? @map("mbti_cert_level")
  bio           String?
  tags          String[]  @default([])
  isBanned      Boolean   @default(false) @map("is_banned")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id])

  @@map("profiles")
}

model Post {
  id            String    @id @default(uuid())
  authorId      String    @map("author_id")
  content       String
  images        String[]  @default([])
  status        PostStatus @default(PENDING)
  rejectReason  String?   @map("reject_reason")
  likeCount     Int       @default(0) @map("like_count")
  commentCount  Int       @default(0) @map("comment_count")
  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  author        User      @relation(fields: [authorId], references: [id])
  likes         PostLike[]
  comments      Comment[]

  @@index([status, createdAt(sort: Desc)])
  @@map("posts")
}

model PostLike {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([postId, userId])
  @@index([postId, userId])
  @@map("post_likes")
}

model Comment {
  id        String    @id @default(uuid())
  postId    String    @map("post_id")
  authorId  String    @map("author_id")
  parentId  String?   @map("parent_id")
  content   String
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  post      Post      @relation(fields: [postId], references: [id])
  author    User      @relation(fields: [authorId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  @@index([postId, parentId, createdAt])
  @@map("comments")
}

model Follows {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower    User     @relation("Follower", fields: [followerId], references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Pass {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  targetId  String   @map("target_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation("PassSent", fields: [userId], references: [id])
  target    User     @relation("PassReceived", fields: [targetId], references: [id])

  @@index([userId, targetId, createdAt])
  @@map("passes")
}

model Match {
  id        String      @id @default(uuid())
  userOneId String      @map("user_one_id")
  userTwoId String      @map("user_two_id")
  status    MatchStatus @default(PENDING)
  createdAt DateTime    @default(now()) @map("created_at")

  userOne   User        @relation("MatchOne", fields: [userOneId], references: [id])
  userTwo   User        @relation("MatchTwo", fields: [userTwoId], references: [id])

  @@unique([userOneId, userTwoId])
  @@index([userOneId, userTwoId])
  @@map("matches")
}

model Conversation {
  id        String    @id @default(uuid())
  userOneId String    @map("user_one_id")
  userTwoId String    @map("user_two_id")
  createdAt DateTime  @default(now()) @map("created_at")

  userOne   User      @relation("ConversationOne", fields: [userOneId], references: [id])
  userTwo   User      @relation("ConversationTwo", fields: [userTwoId], references: [id])
  messages  Message[]

  @@unique([userOneId, userTwoId])
  @@map("conversations")
}

model Message {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  senderId        String    @map("sender_id")
  content         String
  isDeleted       Boolean   @default(false) @map("is_deleted")
  originalContent String?   @map("original_content")
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation    Conversation @relation(fields: [conversationId], references: [id])
  sender          User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  content   String
  isRead    Boolean          @default(false) @map("is_read")
  relatedId String?          @map("related_id")
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model MbtiQuestion {
  id       String   @id @default(uuid())
  level    CertLevel
  dimension String
  content  String
  options  String[]
  weights  Json
  order    Int

  @@map("mbti_questions")
}

model MbtiTestResult {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  level           CertLevel
  mbtiType        String   @map("mbti_type")
  dimensionScores Json     @map("dimension_scores")
  durationSeconds Int?     @map("duration_seconds")
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, level, createdAt(sort: Desc)])
  @@map("mbti_test_results")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String   @map("actor_id")
  action    String
  targetType String? @map("target_type")
  targetId  String?  @map("target_id")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  actor     User     @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}

model GameScore {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  score     Int
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("game_scores")
}

enum Role {
  USER
  ADMIN
}

enum CertLevel {
  basic
  intermediate
  advanced
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MatchStatus {
  PENDING
  MATCHED
}

enum NotificationType {
  FOLLOW
  MATCH
  SYSTEM
}
